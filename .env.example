# Application Configuration
APP_NAME="Enterprise Purple Team Platform"
APP_VERSION="1.0.0"
ENV="development"
DEBUG="true"

# Server
HOST="0.0.0.0"
PORT=8000
RELOAD="true"

# Database
DATABASE_URL="postgresql+asyncpg://admin:password@localhost:5432/purple_team"
DB_ECHO="false"

# Redis
REDIS_URL="redis://localhost:6379/0"

# JWT
JWT_SECRET_KEY="change-this-to-a-strong-secret-key-in-production"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# CORS
CORS_ORIGINS='["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]'

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="json"

# Security
BCRYPT_LOG_ROUNDS=12

# API Keys (for Phase 7+ integrations)
VIRUSTOTAL_API_KEY=""
ALIENVALUT_OTX_API_KEY=""
ABUSEIPDB_API_KEY=""
